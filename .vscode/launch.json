{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Menagerie: Server-side",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/menagerie",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "env": {
        "NODE_OPTIONS": "--inspect"
      },
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Menagerie: Attach to Server",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "cwd": "${workspaceFolder}/apps/menagerie",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "restart": true
    },
    {
      "name": "Menagerie: Attach to Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/apps/menagerie",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${webRoot}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Menagerie: Full Stack (Attach Chrome)",
      "configurations": [
        "Menagerie: Server-side",
        "Menagerie: Attach to Chrome"
      ],
      "stopAll": true
    }
  ]
}