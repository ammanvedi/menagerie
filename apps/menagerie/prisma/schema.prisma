// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String               @id @map("_id")
  email         String               @unique
  name          String?
  emailVerified Boolean
  image         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  sessions      Session[]
  accounts      Account[]
  memberships   OrganisationMember[]

  @@map("users")
}

model Session {
  id        String   @id @map("_id")
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @map("_id")
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ============================================================================
// Menagerie Domain Models
// ============================================================================

model Organisation {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String               @unique
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  members      OrganisationMember[]
  integrations Integration[]
  resources    Resource[]
  agents       Agent[]

  @@map("organisations")
}

model OrganisationMember {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  organisationId String       @db.ObjectId
  role           MemberRole   @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
  @@map("organisation_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Integration {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  slug           String
  name           String
  organisationId String       @db.ObjectId
  config         Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([organisationId, slug])
  @@map("integrations")
}

model Resource {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  slug           String
  name           String
  organisationId String       @db.ObjectId
  config         Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  agentIds       String[]     @db.ObjectId
  agents         Agent[]      @relation(fields: [agentIds], references: [id])

  @@unique([organisationId, slug])
  @@map("resources")
}

model Image {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  dockerfile        String   // Full dockerfile content
  dockerfileHash    String   @unique // SHA256 hash for lookup/deduplication
  deployedImageName String?  // E2B template alias (null if not yet deployed)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agents            Agent[]  // Agents using this image

  @@map("images")
}

model Agent {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  slug           String
  name           String
  avatarType     String?
  organisationId String       @db.ObjectId
  agentTypeSlug  String       // References agent type from YAML config (e.g. "claude-code")
  imageId        String?      @db.ObjectId // Optional relation to cached Image
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  image          Image?       @relation(fields: [imageId], references: [id])
  resourceIds    String[]     @db.ObjectId
  resources      Resource[]   @relation(fields: [resourceIds], references: [id])
  jobs           AgentJob[]

  @@unique([organisationId, slug])
  @@map("agents")
}

model AgentJob {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  agentId       String        @db.ObjectId
  initialPrompt String
  status        AgentJobStatus @default(PENDING)
  sandboxUrl    String?
  createdAt     DateTime      @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  updatedAt     DateTime      @updatedAt
  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_jobs")
}

enum AgentJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}
